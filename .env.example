# Cloudflare API-driven deploy (@suluk/cloudflare, `bun run deploy:cf` — no wrangler). Create an ACCOUNT-scoped
# token (dash.cloudflare.com/profile/api-tokens) with: Workers Scripts (Edit), D1 (Edit), Account Settings (Read);
# add KV/R2 (Edit) if you provision those. CLOUDFLARE_ACCOUNT_ID is optional (the token's first account is used).
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Better Auth (generate: openssl rand -base64 32)
BETTER_AUTH_SECRET=
BASE_URL=http://localhost:3000
# Stripe (https://dashboard.stripe.com/apikeys) — test keys are fine for the demo (card 4242 4242 4242 4242)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Create a webhook endpoint at <BASE_URL>/api/stripe/webhook and paste its signing secret (optional — the
# /checkout/success page confirms payment by retrieving the session, so this is only for server-side events).
STRIPE_WEBHOOK_SECRET=
# Resend email — optional; without it, mail (newsletter welcome, magic links) logs to the console in dev
RESEND_API_KEY=
EMAIL_FROM="saasuluk <onboarding@resend.dev>"
# Google OAuth (https://console.cloud.google.com) — add <BASE_URL>/api/auth/callback/google to the app's
# Authorized redirect URIs. Without these, the "Continue with Google" button is simply inert.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# A JSON array of admin emails. A signed-in user with one of these emails is a verified superadmin (manages the
# catalog/discounts, sees /cost across the store, /superadmin, and /config). Promoted to role:"admin" on sign-up.
SUPERADMIN_EMAILS=["test@example.com"]

# OpenRouter (https://openrouter.ai/keys) — powers the @suluk/chat in-page assistant (the floating bubble that can
# browse the catalog and act on the user's behalf). Without it, /chat returns a graceful 503 and the widget stays inert.
OPENROUTER_API_KEY=

# This config is declared once in src/server/env.ts (@suluk/env) — see /config for its health. Secret VALUES can
# be committed ENCRYPTED (post-quantum, safe to share): `bunx suluk-env encrypt` → public key in .env, private in
# .env.keys (gitignored). At runtime `suluk-env run -- bun dev` (or loadEnv) decrypts. The private key is the only
# secret you must keep out-of-band; everything else can live in git.
