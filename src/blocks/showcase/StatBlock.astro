---
/**
 * StatBlock (tier: BLOCK) — a single metric tile (value + label). Generic; the section supplies the numbers.
 */
interface Props {
  value?: string;
  label?: string;
}
const { value = "100%", label = "Some metric" } = Astro.props;
---

<div class="flex flex-col items-center gap-1 text-center">
  <div class="text-3xl font-extrabold tracking-tight text-foreground sm:text-4xl">{value}</div>
  <div class="text-sm text-muted-foreground">{label}</div>
</div>
