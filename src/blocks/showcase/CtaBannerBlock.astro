---
/**
 * CtaBannerBlock (tier: BLOCK) — a centered heading + subtitle + single CTA. Generic; the section supplies the copy.
 */
import { buttonVariants } from "@/components/ui/button";
import { Icon } from "astro-icon/components";

interface Props {
  title?: string;
  subtitle?: string;
  ctaLabel?: string;
  ctaHref?: string;
}
const { title = "Ready to start?", subtitle = "One last nudge toward the action.", ctaLabel = "Get started", ctaHref = "#" } = Astro.props;
---

<div class="flex flex-col items-center gap-5 text-center">
  <h2 class="max-w-2xl text-3xl font-bold tracking-tight text-balance sm:text-4xl">{title}</h2>
  <p class="max-w-lg text-base text-balance opacity-90 sm:text-lg">{subtitle}</p>
  <a href={ctaHref} class={buttonVariants({ variant: "secondary", size: "lg" })}>
    {ctaLabel}
    <Icon name="material-symbols:arrow-forward-rounded" />
  </a>
</div>
