---
const { title = "saasuluk — SaaS on Suluk" } = Astro.props;
const nav = [["/", "Home"], ["/dashboard", "Dashboard"], ["/pricing", "Pricing"], ["/scalar", "API Docs"], ["/superadmin", "Admin"]];
const path = Astro.url.pathname;
---
<html lang="en">
  <head>
    <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <style is:global>
      :root { color-scheme: dark; --bg:#0b0e14; --panel:#11141c; --line:#1e2433; --fg:#cdd6f4; --muted:#9399b2; --accent:#f5a97f; --link:#8aadf4; }
      * { box-sizing: border-box; } body { margin:0; font:15px/1.65 -apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; background:var(--bg); color:var(--fg); }
      a { color:var(--link); text-decoration:none; } a:hover { text-decoration:underline; }
      header { position:sticky; top:0; display:flex; gap:18px; align-items:center; padding:13px 22px; border-bottom:1px solid var(--line); background:rgba(11,14,20,.9); backdrop-filter:blur(6px); }
      header .brand { color:var(--accent); font-weight:700; letter-spacing:.04em; } nav { display:flex; gap:16px; } nav a { color:var(--muted); font-size:14px; } nav a.on { color:var(--accent); }
      main { max-width:920px; margin:0 auto; padding:28px 22px 64px; }
      h1 { font-size:40px; margin:0 0 8px; letter-spacing:-.01em; } .tag { font-size:18px; color:var(--muted); max-width:62ch; }
      .btn { display:inline-block; background:var(--accent); color:#11141c; padding:8px 16px; border-radius:8px; font-weight:600; } .btn.ghost { background:transparent; color:var(--fg); border:1px solid var(--line); }
      .grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:12px; margin-top:18px; }
      .card { background:var(--panel); border:1px solid var(--line); border-radius:10px; padding:14px 16px; } .card b { color:var(--accent); font-family:ui-monospace,monospace; font-size:13px; } .card p { color:var(--muted); font-size:13.5px; margin:5px 0 0; }
      h2 { color:var(--accent); font-size:13px; text-transform:uppercase; letter-spacing:.07em; margin:30px 0 8px; }
      input,select { background:#11141c; color:var(--fg); border:1px solid var(--line); border-radius:6px; padding:6px 9px; } table { width:100%; border-collapse:collapse; } th,td { text-align:left; padding:7px 9px; border-bottom:1px solid var(--line); } th { color:var(--muted); }
      .pill { background:var(--line); color:var(--muted); border-radius:99px; padding:1px 8px; font-size:11px; }
    </style>
  </head>
  <body>
    <header>
      <a class="brand" href="/">saasuluk</a>
      <nav>{nav.map(([href, label]) => <a href={href} class={path === href ? "on" : ""}>{label}</a>)}</nav>
    </header>
    <main><slot /></main>
  </body>
</html>
