      <div class="mobilenav-head"><a class="brand" href="/"><span class="dot">s</span> saasuluk</a><button id="navclose" class="iconbtn" aria-label="Close menu">✕</button></div>
      <nav>{nav.map(([href, key]) => <a href={href} data-i18n={key} class={path === href ? "on" : ""} aria-current={path === href ? "page" : undefined}>{t("en", key)}</a>)}</nav>
      <div class="mnav-actions">
