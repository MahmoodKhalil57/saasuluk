    <script is:inline set:html={`window.__schemes=${JSON.stringify(SCHEME_SWATCHES)}`}></script>
    <script is:inline>
      if (window.__applyLang) window.__applyLang(window.__lang0);
      (function () {
        var root = document.documentElement, mq = window.matchMedia ? matchMedia("(prefers-color-scheme: dark)") : null;
        var ICONS = {
          light: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>',
          dark: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6.36 6.36 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>',
          system: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>'
        };
        var THEMES = ["light", "dark", "system"], tbtn = document.getElementById("theme"), mLabel = document.getElementById("m-theme-label");
        function applyTheme(pref) {
          root.dataset.theme = pref === "system" ? (mq && mq.matches ? "dark" : "light") : pref;
          root.dataset.themePref = pref;
          try { localStorage.setItem("theme", pref); } catch (e) {}
          if (tbtn) { tbtn.innerHTML = ICONS[pref]; tbtn.setAttribute("aria-label", "Theme: " + pref + " — click to change"); }
          if (mLabel) mLabel.textContent = pref;
          if (popOpen) renderGrid(search ? search.value : ""); // swatches preview the active light/dark mode
        }
        function cycleTheme(e) {
          var cur = root.dataset.themePref || "system", next = THEMES[(THEMES.indexOf(cur) + 1) % 3];
          var btn = (e && e.currentTarget && e.currentTarget.getBoundingClientRect) ? e.currentTarget : tbtn;
          if (!document.startViewTransition || !btn) { applyTheme(next); return; }
          document.startViewTransition(function () { applyTheme(next); }).ready.then(function () {
            var r = btn.getBoundingClientRect(), x = r.left + r.width / 2, y = r.top + r.height / 2;
            var rad = Math.hypot(Math.max(x, innerWidth - x), Math.max(y, innerHeight - y));
            root.animate({ clipPath: ["circle(0px at " + x + "px " + y + "px)", "circle(" + rad + "px at " + x + "px " + y + "px)"] },
              { duration: 480, easing: "ease-in-out", pseudoElement: "::view-transition-new(root)" });
          }).catch(function () {});
        }
        if (tbtn) { applyTheme(root.dataset.themePref || "system"); tbtn.addEventListener("click", cycleTheme); }
        if (mq) mq.addEventListener("change", function () { if ((root.dataset.themePref || "system") === "system") applyTheme("system"); });

        // ── color-scheme popover (swatches DERIVED from @suluk/theme — never hand-maintained) ──
        var pop = document.getElementById("schemepop"), back = document.getElementById("schemeback"), grid = document.getElementById("scheme-grid"),
            sbtn = document.getElementById("scheme-btn"), search = document.getElementById("scheme-search"), swatches = window.__schemes || [], popOpen = false;
        function cur() { return root.dataset.scheme || ""; }
        function esc(s) { return String(s).replace(/[&<>"]/g, function (c) { return ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" })[c]; }); }
        function card(s) {
          var cols = (root.dataset.theme === "dark" ? s.dark : s.light) || [];
          var sw = cols.map(function (c) { return '<i style="background:' + esc(c) + '"></i>'; }).join("");
          var on = s.name === cur() ? " on" : "";
          return '<button class="scheme-card' + on + '" role="option" aria-selected="' + (on ? "true" : "false") + '" data-scheme="' + esc(s.name) + '"><span class="scheme-sw">' + sw + '</span><span class="scheme-name">' + esc(s.label) + '</span></button>';
        }
        function renderGrid(q) {
          if (!grid) return; q = (q || "").toLowerCase();
          var list = swatches.filter(function (s) { return !q || s.label.toLowerCase().indexOf(q) >= 0; });
          grid.innerHTML = list.length ? list.map(card).join("") : '<p class="scheme-empty">No schemes match.</p>';
        }
        function setScheme(name) {
          if (name) { root.dataset.scheme = name; try { localStorage.setItem("scheme", name); } catch (e) {} }
          else { delete root.dataset.scheme; try { localStorage.removeItem("scheme"); } catch (e) {} }
          renderGrid(search ? search.value : "");
        }
        function openPop() { if (!pop) return; renderGrid(""); pop.hidden = false; if (back) back.hidden = false; requestAnimationFrame(function () { pop.classList.add("open"); if (back) back.classList.add("open"); }); pop.setAttribute("aria-hidden", "false"); if (sbtn) sbtn.setAttribute("aria-expanded", "true"); popOpen = true; setTimeout(function () { if (search) search.focus(); }, 40); }
        function closePop() { if (!pop) return; pop.classList.remove("open"); if (back) back.classList.remove("open"); pop.setAttribute("aria-hidden", "true"); if (sbtn) sbtn.setAttribute("aria-expanded", "false"); popOpen = false; setTimeout(function () { pop.hidden = true; if (back) back.hidden = true; }, 180); }
        if (sbtn) sbtn.addEventListener("click", function () { popOpen ? closePop() : openPop(); });
        if (back) back.addEventListener("click", closePop);
        if (search) search.addEventListener("input", function () { renderGrid(search.value); });
        if (grid) grid.addEventListener("click", function (e) { var c = e.target.closest && e.target.closest("[data-scheme]"); if (c) setScheme(c.getAttribute("data-scheme")); });
        document.addEventListener("keydown", function (e) { if (e.key === "Escape" && popOpen) closePop(); });

        // ── glassy scroll state + scroll-progress hairline ──
        var hdr = document.getElementById("site-header"), prog = document.getElementById("scrollprog");
        function onScroll() {
          var y = window.scrollY || 0;
          if (hdr) hdr.classList.toggle("scrolled", y > 6);
          if (prog) { var h = document.documentElement.scrollHeight - innerHeight; prog.style.width = (h > 0 ? (y / h) * 100 : 0) + "%"; }
        }
        addEventListener("scroll", onScroll, { passive: true }); onScroll();

        // ── cart bump on change ──
        var cbtn = document.getElementById("cartbtn");
        addEventListener("cart-changed", function () { if (cbtn) { cbtn.classList.remove("bump"); void cbtn.offsetWidth; cbtn.classList.add("bump"); } });

        // ── mobile drawer actions delegate to the header controls ──
        document.querySelectorAll("[data-act]").forEach(function (b) {
          b.addEventListener("click", function () {
            var act = b.getAttribute("data-act"), nc = document.getElementById("navclose"); if (nc) nc.click();
            setTimeout(function () {
              if (act === "search") { var p = document.getElementById("palette-open"); if (p) p.click(); }
              else if (act === "scheme") openPop();
              else if (act === "theme") cycleTheme();
            }, 60);
          });
        });
        var mlang = document.getElementById("m-lang");
        if (mlang) { mlang.value = (window.__lang0 || "en"); mlang.addEventListener("change", function (e) { var L = document.getElementById("lang"); if (L) { L.value = e.target.value; L.dispatchEvent(new Event("change")); } }); }
      })();
      document.getElementById("lang").addEventListener("change", function (e) {
        try { localStorage.setItem("lang", e.target.value); } catch (x) {}
        document.cookie = "lang=" + e.target.value + ";path=/;max-age=31536000;samesite=lax";
        if (window.__applyLang) window.__applyLang(e.target.value);
        window.dispatchEvent(new Event("locale-changed")); // re-render localized money/dates (cart drawer + pages)
      });
      if ("serviceWorker" in navigator) navigator.serviceWorker.register("/sw.js").catch(function () {});
      // Session-aware account menu: confirm the session, fill the avatar + name + dropdown, cache the hint for a
      // flash-free next paint, and wire the dropdown + sign-out. Replaces the bolted-on avatar LINK with a real menu.
      (function () {
        var signin = document.getElementById("authsignin"), btn = document.getElementById("authbtn"), pop = document.getElementById("authpop");
        if (!btn) return;
        function setIn(u) {
          var name = u.name || (u.email || "").split("@")[0];
          var img = u.image || ("/avatar?seed=" + encodeURIComponent(u.email || name));
          document.getElementById("authavatar").src = img;
          document.getElementById("authname").textContent = name;
          document.getElementById("authpopavatar").src = img;
          document.getElementById("authpopname").textContent = name;
          document.getElementById("authpopemail").textContent = u.email || "";
          btn.hidden = false; if (signin) signin.hidden = true;
          try { localStorage.setItem("su_user", JSON.stringify({ name: name, email: u.email, image: u.image })); } catch (e) {}
        }
        function setOut() {
          btn.hidden = true; if (pop) pop.hidden = true; if (signin) signin.hidden = false;
          try { localStorage.removeItem("su_user"); } catch (e) {}
        }
        fetch("/api/auth/get-session", { credentials: "same-origin" }).then(function (r) { return r.ok ? r.json() : null; })
          .then(function (s) { var u = s && s.user; if (u) setIn(u); else setOut(); }).catch(function () {});
        btn.addEventListener("click", function (e) { e.stopPropagation(); var willOpen = pop.hidden; pop.hidden = !willOpen; btn.setAttribute("aria-expanded", String(willOpen)); });
        document.addEventListener("click", function (e) { if (pop && !pop.hidden && !pop.contains(e.target) && !btn.contains(e.target)) { pop.hidden = true; btn.setAttribute("aria-expanded", "false"); } });
        document.addEventListener("keydown", function (e) { if (e.key === "Escape" && pop && !pop.hidden) { pop.hidden = true; btn.setAttribute("aria-expanded", "false"); btn.focus(); } });
        var so = document.getElementById("authsignout");
        if (so) so.addEventListener("click", function () { so.textContent = "Signing out…"; fetch("/api/auth/sign-out", { method: "POST", credentials: "same-origin" }).then(function () { setOut(); location.reload(); }).catch(function () { location.href = "/login"; }); });
      })();
    </script>
    <script is:inline set:html={skewGuardScript()}></script>
    <script is:inline>
      /* Global client backstop — a silent fetch rejection or runtime error should never just vanish. Warn always; show
         ONE debounced toast (every 8s max) so the user knows to retry. Guarded so it never throws or spams. */
      (function () {
        var last = 0;
        function notify() { var now = Date.now(); if (now - last < 8000) return; last = now; if (window.toast) window.toast("Something went wrong. Please try again.", { type: "error" }); }
        window.addEventListener("unhandledrejection", function (e) { try { console.warn("[saasuluk] unhandled rejection:", e && e.reason); } catch (_) {} notify(); });
        window.addEventListener("error", function (e) { try { console.warn("[saasuluk] error:", e && (e.message || e.error)); } catch (_) {} });
      })();
    </script>
    <!-- Browser-executed CLIENT TOOLS the @suluk/chat agent can call: cart (works logged-out — the cart is local),
         theme/scheme, and same-site navigation. Only DEFINITIONS go to the model; run() executes here in the page. -->
    <script is:inline>
      (function () {
        function num(v) { var n = Number(v); return Number.isFinite(n) ? n : 0; }
        function readCart() { try { return JSON.parse(localStorage.getItem("cart") || "[]"); } catch (e) { return []; } }
        var schemes = (window.__schemes || []).map(function (s) { return s.name; });
        window.__sulukChatContext = function () {
          var c = readCart();
          return { path: location.pathname, theme: localStorage.getItem("theme") || "system", scheme: document.documentElement.dataset.scheme || "default",
            availableSchemes: schemes, cart: c, cartCount: c.reduce(function (n, l) { return n + (l.qty || 0); }, 0),
            subtotalCents: c.reduce(function (n, l) { return n + (l.qty || 0) * (l.priceCents || 0); }, 0) };
        };
        window.__sulukChatTools = [
          { name: "addToCart", description: "Add a product to the shopping cart by its numeric product id (find the id via search/listProduct first). Quantity defaults to 1. Works without signing in.",
            parameters: { type: "object", properties: { productId: { type: "integer", description: "the product's numeric id" }, quantity: { type: "integer", description: "how many (default 1)" } }, required: ["productId"] },
            run: function (a) { var id = num(a.productId), qty = Math.max(1, num(a.quantity) || 1);
              return fetch("/product/" + encodeURIComponent(id)).then(function (r) { return r.ok ? r.json() : null; }).then(function (p) { if (p && window.cart && window.cart.add) window.cart.add({ productId: id, qty: qty, priceCents: num(p.priceCents), name: String(p.name || ("#" + id)) }); }); } },
          { name: "removeFromCart", description: "Remove a product from the cart by its numeric product id.",
            parameters: { type: "object", properties: { productId: { type: "integer" } }, required: ["productId"] },
            run: function (a) { if (window.cart && window.cart.remove) window.cart.remove(num(a.productId)); } },
          { name: "setCartQuantity", description: "Set the quantity of a product already in the cart (0 removes it).",
            parameters: { type: "object", properties: { productId: { type: "integer" }, quantity: { type: "integer" } }, required: ["productId", "quantity"] },
            run: function (a) { if (window.cart && window.cart.setQty) window.cart.setQty(num(a.productId), Math.max(0, num(a.quantity))); } },
          { name: "clearCart", description: "Empty the shopping cart.", parameters: { type: "object", properties: {} },
            run: function () { if (window.cart && window.cart.clear) window.cart.clear(); } },
          { name: "openCart", description: "Open the cart drawer so the user can review their items.", parameters: { type: "object", properties: {} },
            run: function () { var b = document.getElementById("cartbtn"); if (b) b.click(); } },
          { name: "goToCheckout", description: "Go to the checkout page.", parameters: { type: "object", properties: {} },
            run: function () { location.href = "/checkout"; } },
          { name: "setTheme", description: "Switch the site between light and dark mode, or follow the operating system.",
            parameters: { type: "object", properties: { mode: { type: "string", enum: ["light", "dark", "system"] } }, required: ["mode"] },
            run: function (a) { var m = a.mode === "dark" ? "dark" : a.mode === "light" ? "light" : "system"; try { localStorage.setItem("theme", m); } catch (e) {} document.documentElement.dataset.theme = m === "system" ? (matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light") : m; } },
          { name: "setColorScheme", description: "Apply a named color scheme to the whole site. Use one of the names listed in availableSchemes (browser state).",
            parameters: { type: "object", properties: { scheme: { type: "string" } }, required: ["scheme"] },
            run: function (a) { var n = String(a.scheme || ""); if (!schemes.length || schemes.indexOf(n) >= 0) { document.documentElement.dataset.scheme = n; try { localStorage.setItem("scheme", n); } catch (e) {} } } },
          { name: "navigate", description: "Navigate to a page on this site. Use a same-site path such as /products, /pricing, /products/<slug>, /blogs, /faqs, or /dashboard.",
            parameters: { type: "object", properties: { path: { type: "string" } }, required: ["path"] },
            run: function (a) { var p = String(a.path || ""); if (p === "/" || /^\/[^\/\\]/.test(p)) location.href = p; } }
        ];
      })();
    </script>
    <!-- @suluk/chat — the floating, contract-driven assistant (browse + act). Baked into the static shell; its
         script talks to the worker's /chat SSE endpoint. Theme-aware via the same CSS vars as the rest of the site. -->
    <Fragment set:html={chatWidget({ title: "saasuluk assistant" })} />
  </body>
</html>
