---
import { t, LOCALES, LOCALE_LABEL, RTL, DICT } from "../i18n";
const { title = "saasuluk — SaaS on Suluk" } = Astro.props;
// The frontend is static (prerendered / Cloudflare assets), so locale + theme are applied CLIENT-SIDE. We render
// the English chrome with a data-i18n key on each label; the inline script below swaps it to the stored locale
// and sets <html lang/dir> (RTL for Arabic). One dictionary (src/i18n.ts), shared by render + client.
type Key = Parameters<typeof t>[1];
const nav: [string, Key][] = [["/", "home"], ["/products", "products"], ["/blogs", "blog"], ["/pricing", "pricing"], ["/dashboard", "dashboard"], ["/account", "account"]];
const footer: [string, Key][] = [["/faqs", "faq"], ["/contact", "contact"], ["/about", "about"], ["/metrics", "metrics"], ["/scalar", "docs"], ["/superadmin", "admin"], ["/privacy", "privacy"], ["/terms", "terms"], ["/license", "license"]];
const path = Astro.url.pathname;
---
<html lang="en" dir="ltr">
  <head>
    <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="theme-color" content="#0b0e14" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {/* apply theme + locale before paint to avoid a flash */}
    <script is:inline define:vars={{ DICT, RTL }}>
      (function () {
        try { document.documentElement.dataset.theme = localStorage.getItem("theme") || "dark"; } catch (e) {}
        function curLang() { try { return localStorage.getItem("lang") || (document.cookie.match(/(?:^|; )lang=(\w+)/) || [])[1] || "en"; } catch (e) { return "en"; } }
        window.__applyLang = function (l) {
          var d = document.documentElement; d.lang = l; d.dir = (RTL.indexOf(l) >= 0 ? "rtl" : "ltr");
          document.querySelectorAll("[data-i18n]").forEach(function (el) { var k = el.getAttribute("data-i18n"); if (DICT[l] && DICT[l][k]) el.textContent = DICT[l][k]; });
          var sel = document.getElementById("lang"); if (sel) sel.value = l;
        };
        window.__lang0 = curLang();
        document.documentElement.lang = window.__lang0; document.documentElement.dir = (RTL.indexOf(window.__lang0) >= 0 ? "rtl" : "ltr");
      })();
    </script>
    <style is:global>
      :root, html[data-theme="dark"] { color-scheme: dark; --bg:#0b0e14; --panel:#11141c; --line:#1e2433; --fg:#cdd6f4; --muted:#9399b2; --accent:#f5a97f; --link:#8aadf4; }
      html[data-theme="light"] { color-scheme: light; --bg:#f7f8fc; --panel:#ffffff; --line:#e3e6ef; --fg:#1a1d29; --muted:#5b6276; --accent:#d9762f; --link:#3b5bdb; }
      * { box-sizing: border-box; } body { margin:0; font:15px/1.65 -apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; background:var(--bg); color:var(--fg); }
      a { color:var(--link); text-decoration:none; } a:hover { text-decoration:underline; }
      header { position:sticky; top:0; z-index:10; display:flex; gap:18px; align-items:center; padding:13px 22px; border-bottom:1px solid var(--line); background:color-mix(in srgb, var(--bg) 90%, transparent); backdrop-filter:blur(6px); }
      header .brand { color:var(--accent); font-weight:700; letter-spacing:.04em; } nav { display:flex; gap:16px; } nav a { color:var(--muted); font-size:14px; } nav a.on { color:var(--accent); }
      main { max-width:920px; margin:0 auto; padding:28px 22px 64px; }
      h1 { font-size:40px; margin:0 0 8px; letter-spacing:-.01em; } .tag { font-size:18px; color:var(--muted); max-width:62ch; }
      .btn { display:inline-block; background:var(--accent); color:var(--bg); padding:8px 16px; border-radius:8px; font-weight:600; cursor:pointer; border:0; } .btn.ghost { background:transparent; color:var(--fg); border:1px solid var(--line); }
      .grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:12px; margin-top:18px; }
      .card { background:var(--panel); border:1px solid var(--line); border-radius:10px; padding:14px 16px; } .card b { color:var(--accent); font-family:ui-monospace,monospace; font-size:13px; } .card p { color:var(--muted); font-size:13.5px; margin:5px 0 0; }
      h2 { color:var(--accent); font-size:13px; text-transform:uppercase; letter-spacing:.07em; margin:30px 0 8px; }
      input,select,textarea { background:var(--panel); color:var(--fg); border:1px solid var(--line); border-radius:6px; padding:6px 9px; font:inherit; } table { width:100%; border-collapse:collapse; } th,td { text-align:start; padding:7px 9px; border-bottom:1px solid var(--line); } th { color:var(--muted); }
      .pill { background:var(--line); color:var(--muted); border-radius:99px; padding:1px 8px; font-size:11px; }
      .chrome { margin-inline-start:auto; display:flex; gap:8px; align-items:center; }
      .chrome select, .chrome button { font-size:13px; padding:4px 8px; }
    </style>
  </head>
  <body>
    <header>
      <a class="brand" href="/">saasuluk</a>
      <nav>{nav.map(([href, key]) => <a href={href} data-i18n={key} class={path === href ? "on" : ""}>{t("en", key)}</a>)}</nav>
      <div class="chrome">
        <select id="lang" aria-label="Language">{LOCALES.map((l) => <option value={l}>{LOCALE_LABEL[l]}</option>)}</select>
        <button id="theme" class="btn ghost" aria-label="Toggle theme">◐</button>
      </div>
    </header>
    <main><slot /></main>
    <footer style="border-top:1px solid var(--line); margin-top:40px">
      <div style="max-width:920px; margin:0 auto; padding:20px 22px; display:flex; flex-wrap:wrap; gap:14px; align-items:center">
        <span style="color:var(--muted); font-size:13px">saasuluk — <span data-i18n="tagline">{t("en", "tagline")}</span></span>
        <nav style="margin-inline-start:auto; flex-wrap:wrap">{footer.map(([href, key]) => <a href={href} data-i18n={key} class={path === href ? "on" : ""} style="font-size:13px">{t("en", key)}</a>)}</nav>
      </div>
    </footer>
    <script is:inline>
      if (window.__applyLang) window.__applyLang(window.__lang0); // translate the chrome to the stored locale
      document.getElementById("theme").addEventListener("click", function () {
        var next = document.documentElement.dataset.theme === "light" ? "dark" : "light";
        document.documentElement.dataset.theme = next; try { localStorage.setItem("theme", next); } catch (e) {}
      });
      document.getElementById("lang").addEventListener("change", function (e) {
        try { localStorage.setItem("lang", e.target.value); } catch (x) {}
        document.cookie = "lang=" + e.target.value + ";path=/;max-age=31536000;samesite=lax";
        if (window.__applyLang) window.__applyLang(e.target.value);
      });
      if ("serviceWorker" in navigator) navigator.serviceWorker.register("/sw.js").catch(function () {});
    </script>
  </body>
</html>
