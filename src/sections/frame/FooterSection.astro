 * FooterSection (tier: SECTION) — the footer band that wraps SiteFooter at the bottom of the page frame. Composes the
 * SiteFooter block. Rendered by Layout for every page.
 */
import SiteFooter from "@/blocks/footer/SiteFooter.astro";
---

<footer class="sk-tw w-full border-t border-border bg-[color-mix(in_oklab,var(--color-secondary)_40%,var(--color-background))]">
  <SiteFooter />
</footer>
