---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
---

<Layout title="Not found — saasuluk">
  <section class="hero" style="padding:80px 0">
    <span class="pill accent">404</span>
    <h1 style="margin-top:16px">This page <span class="gradient">drifted away.</span></h1>
    <p class="tag center">
      Unlike the rest of the stack — which can't drift, because every layer is one contract. This page just isn't one of them.
    </p>
    <div class="cta">
      <a class="btn" href="/products">Back to the store →</a>
      <a class="btn ghost" href="/">Home</a>
    </div>
  </section>
</Layout>
