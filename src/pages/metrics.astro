---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
---
<Layout title="Metrics — saasuluk" description="Live saasuluk metrics — orders, revenue, and API usage projected straight from the contract-metered ledger. Real numbers, not a mockup.">
  <h1>Metrics</h1>
  <p class="tag">Store analytics — derived from <b>Order</b> rows by the <code>/analytics/*</code> operations (declared <code>x-suluk-access: admin</code> and ENFORCED on the wire), plus the live <code>/cost</code> ledger. (saastarter wires Recharts + admin routes; here it is three contract operations.)</p>
  <div id="gate" class="card" style="display:none;margin-top:18px;border-color:var(--accent)"></div>
  <div class="grid" id="summary" style="margin-top:18px"></div>
  <h2>Revenue (last 30 days)</h2>
  <div id="revenue" class="card"></div>
  <h2>Top products</h2>
  <table><thead><tr><th>Product</th><th>Units</th><th>Price</th></tr></thead><tbody id="top"></tbody></table>
  <h2>Cost ledger (what the app spent)</h2>
  <pre id="cost" class="card" style="white-space:pre-wrap;font-family:ui-monospace,monospace;font-size:12.5px"></pre>
  <script is:inline>
    const money = (c) => (window.fmtMoney ? window.fmtMoney(c) : "$" + (Number(c || 0) / 100).toFixed(2));
    async function load() {
      try {
      const r = await fetch("/analytics/summary");
      if (r.status === 401 || r.status === 403) { // analytics are admin-only — the wire enforces x-suluk-access
        const g = document.getElementById("gate");
        g.style.display = "block";
        g.innerHTML = `<b>Admin-only.</b> Store revenue and customer analytics are <code>x-suluk-access: admin</code>, enforced on the wire (you got <b>${r.status}</b>). Sign in as a superadmin (and open <a href="/superadmin">/superadmin</a>) to view them — exactly the access model saastarter ships.`;
        for (const id of ["summary", "revenue", "top"]) document.getElementById(id).innerHTML = "";
        document.getElementById("cost").textContent = JSON.stringify(await (await fetch("/cost")).json(), null, 2); // /cost is owner-scoped, still readable
        return;
      }
      const s = await r.json();
      document.getElementById("summary").innerHTML = [["Orders", s.orders], ["Paid", s.paidOrders], ["Revenue", money(s.revenueCents)], ["Customers", s.customers], ["Products", s.products]].map(([k, v]) => `<div class="card"><p style="margin:0;font-size:12px">${k}</p><b style="font-family:inherit;font-size:22px">${v}</b></div>`).join("");
      const rev = (await (await fetch("/analytics/revenue")).json()).series || [];
      const max = Math.max(1, ...rev.map((d) => d.revenueCents));
      document.getElementById("revenue").innerHTML = rev.length ? rev.map((d) => `<div style="display:flex;align-items:center;gap:8px;margin:3px 0"><span style="width:84px;color:var(--muted);font-size:12px">${d.date}</span><span style="height:14px;background:var(--accent);border-radius:3px;width:${Math.round((d.revenueCents / max) * 260)}px"></span><span style="font-size:12px">${money(d.revenueCents)}</span></div>`).join("") : `<span style="color:var(--muted)">No paid orders yet.</span>`;
      const top = (await (await fetch("/analytics/top-products")).json()).topProducts || [];
      document.getElementById("top").innerHTML = top.length ? top.map((p) => `<tr><td>${p.name}</td><td>${p.qty}</td><td>${money(p.priceCents)}</td></tr>`).join("") : `<tr><td colspan="3" style="color:var(--muted)">No sales yet.</td></tr>`;
      document.getElementById("cost").textContent = JSON.stringify(await (await fetch("/cost")).json(), null, 2);
      } catch (e) { // a network/5xx error must surface, not fail silent (only 401/403 was handled before)
        const g = document.getElementById("gate"); g.style.display = "block";
        g.innerHTML = `Couldn't load metrics — the analytics service didn't respond. <button class="btn ghost" id="mRetry" style="margin-inline-start:8px">Retry</button>`;
        const b = document.getElementById("mRetry"); if (b) b.addEventListener("click", () => { g.style.display = "none"; load(); });
      }
    }
    load();
  </script>
</Layout>
