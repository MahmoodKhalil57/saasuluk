---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
---
<Layout title="Blog — saasuluk" description="The saasuluk blog — notes on contract-first development, Cloudflare Workers, Stripe, and building a SaaS + ecommerce starter that ships itself.">
  <h1>Blog</h1>
  <p class="tag">Posts are a <b>Post</b> entity — authored in <a href="/superadmin">/superadmin</a>, served by the contract, rendered here.</p>
  <div id="posts" style="margin-top:18px"></div>
  <script is:inline>
    const when = (t) => t ? (window.fmtDate ? window.fmtDate(Number(t)) : new Date(Number(t)).toLocaleDateString()) : "";
    function skeleton(n) {
      document.getElementById("posts").innerHTML = Array.from({ length: n }, () => `<article class="card" style="margin-bottom:12px">
        <div class="skel" style="height:20px;width:55%;margin-bottom:9px"></div>
        <div class="skel" style="height:11px;width:90px;margin-bottom:11px"></div>
        <div class="skel" style="height:13px;width:97%;margin-bottom:6px"></div>
        <div class="skel" style="height:13px;width:80%"></div></article>`).join("");
    }
    async function load() {
      skeleton(4); // shimmer placeholders until the fetch resolves
      try {
        const res = await fetch("/post");
        if (!res.ok) throw new Error("HTTP " + res.status);
        const posts = (await res.json()).filter((p) => p.status === "published").sort((a, b) => (b.publishedAt || 0) - (a.publishedAt || 0));
        document.getElementById("posts").innerHTML = posts.length ? posts.map((p) => `
        <article class="card" style="margin-bottom:12px;padding:0;overflow:hidden">
          ${p.coverImageUrl ? `<a href="/blogs/${p.slug}" style="display:block;aspect-ratio:16/9;overflow:hidden"><img src="${p.coverImageUrl}" alt="" style="width:100%;height:100%;object-fit:cover;display:block" loading="lazy" /></a>` : ""}
          <div style="padding:16px 18px">
            <a href="/blogs/${p.slug}"><b style="font-family:inherit;font-size:18px">${p.title}</b></a>
            <p style="color:var(--muted);font-size:12px;margin:3px 0">${when(p.publishedAt)}</p>
            <p>${p.excerpt || ""}</p><a href="/blogs/${p.slug}">Read more →</a>
          </div>
        </article>`).join("") : `<p style="color:var(--muted)">No posts yet.</p>`;
      } catch (e) { // never leave the skeleton up on a failed fetch
        document.getElementById("posts").innerHTML = `<div class="card" style="text-align:center;padding:30px"><p style="margin:0 0 12px;color:var(--muted)">Couldn't load the blog. Check your connection and try again.</p><button class="btn ghost" id="blogRetry">Retry</button></div>`;
        document.getElementById("blogRetry").addEventListener("click", load);
      }
    }
    load();
  </script>
</Layout>
