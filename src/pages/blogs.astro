---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
---
<Layout title="Blog — saasuluk">
  <h1>Blog</h1>
  <p class="tag">Posts are a <b>Post</b> entity — authored in <a href="/superadmin">/superadmin</a>, served by the contract, rendered here.</p>
  <div id="posts" style="margin-top:18px"></div>
  <script is:inline>
    const when = (t) => t ? new Date(Number(t)).toLocaleDateString() : "";
    function skeleton(n) {
      document.getElementById("posts").innerHTML = Array.from({ length: n }, () => `<article class="card" style="margin-bottom:12px">
        <div class="skel" style="height:20px;width:55%;margin-bottom:9px"></div>
        <div class="skel" style="height:11px;width:90px;margin-bottom:11px"></div>
        <div class="skel" style="height:13px;width:97%;margin-bottom:6px"></div>
        <div class="skel" style="height:13px;width:80%"></div></article>`).join("");
    }
    async function load() {
      skeleton(4); // shimmer placeholders until the fetch resolves
      const posts = (await (await fetch("/post")).json()).filter((p) => p.status === "published").sort((a, b) => (b.publishedAt || 0) - (a.publishedAt || 0));
      document.getElementById("posts").innerHTML = posts.length ? posts.map((p) => `
        <article class="card" style="margin-bottom:12px">
          <a href="/blogs/${p.slug}"><b style="font-family:inherit;font-size:18px">${p.title}</b></a>
          <p style="color:var(--muted);font-size:12px;margin:3px 0">${when(p.publishedAt)}</p>
          <p>${p.excerpt || ""}</p><a href="/blogs/${p.slug}">Read more →</a>
        </article>`).join("") : `<p style="color:var(--muted)">No posts yet.</p>`;
    }
    load();
  </script>
</Layout>
