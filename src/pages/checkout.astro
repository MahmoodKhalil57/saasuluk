---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
---
<Layout title="Checkout — saasuluk">
  <!-- is:global so the order-summary lines/thumbnails (built via innerHTML at runtime) are styled (a scoped style
       only matches build-time elements; runtime-injected ones lack the scope attribute → the 52px thumb wouldn't apply). -->
  <style is:global>
    .co-grid { display:grid; grid-template-columns:1fr; gap:18px; max-width:620px; margin-top:18px; }
    .co-card { padding:18px 20px; }
    .co-line { display:flex; gap:13px; align-items:center; padding:11px 0; border-bottom:1px solid var(--line); }
    .co-line:last-of-type { border-bottom:0; }
    .co-img { width:52px; height:52px; flex:none; border-radius:9px; object-fit:cover; border:1px solid var(--line); background:var(--bg-soft); }
    .co-line-body { flex:1; min-width:0; }
    .co-name { font-weight:600; font-size:14.5px; }
    .co-variant { font-size:12.5px; color:var(--muted); margin-top:1px; }
    .co-qty { font-size:12.5px; color:var(--muted); margin-top:1px; }
    .co-line-price { font-family:ui-monospace,monospace; font-size:14px; white-space:nowrap; }
    .co-disc { display:flex; gap:8px; align-items:center; flex-wrap:wrap; margin:16px 0 4px; }
    .co-disc input { flex:1; min-width:160px; }
    .co-applied { display:inline-flex; align-items:center; gap:6px; font-size:13px; color:var(--accent); font-weight:600; }
    .co-applied button { border:0; background:none; color:var(--muted); cursor:pointer; font-size:15px; line-height:1; padding:0 2px; }
    .co-msg { font-size:13px; }
    .co-totals { margin-top:14px; border-top:1px solid var(--line); padding-top:12px; }
    .co-trow { display:flex; justify-content:space-between; font-size:14.5px; padding:3px 0; }
    .co-trow span:last-child { font-family:ui-monospace,monospace; }
    .co-trow.total { font-size:19px; font-weight:800; margin-top:6px; padding-top:8px; border-top:1px solid var(--line); }
    .co-trow.total span:last-child { color:var(--accent); }
    .co-trow.disc span { color:var(--accent); }
    #placeOrder { width:100%; justify-content:center; font-size:16px; padding:13px; }
    .co-note { color:var(--muted); font-size:12.5px; margin-top:9px; text-align:center; }
    .addr-grid { display:grid; grid-template-columns:1fr 1fr; gap:9px; margin-top:4px; }
    .addr-grid input { width:100%; }
    .addr-grid .addr-full { grid-column:1 / -1; }
    .addr-hint { color:var(--muted); font-size:12.5px; margin:0 0 12px; }
    .co-contact { margin:15px 0 4px; }
    .co-contact label { display:block; font-size:13px; font-weight:600; margin-bottom:6px; }
    .co-contact input { width:100%; }
    .co-contact input[readonly] { opacity:.7; cursor:not-allowed; }
    .co-contact .co-contact-hint { font-size:12px; color:var(--accent); margin-top:4px; display:inline-block; }
    .co-banner { padding:11px 14px; border-radius:10px; margin:14px 0 2px; font-size:13.5px; max-width:620px; }
    .co-banner.info { background:color-mix(in srgb, var(--accent) 8%, var(--panel)); border:1px solid color-mix(in srgb, var(--accent) 28%, var(--line)); }
    .co-banner.signin { background:var(--bg-soft); border:1px solid var(--line); color:var(--muted); }
    .co-banner a { font-weight:600; }
  </style>

  <h1>Checkout</h1>
  <p class="tag">Your cart becomes an <b>Order</b> — server re-prices every line from the catalog, applies your discount, and (when the total is $0) completes for free without Stripe.</p>
  <div id="coBanner" class="co-banner" hidden></div>

  <div class="co-grid">
    <div class="co-card card">
      <h2 style="margin-top:0">Order summary</h2>
      <div id="lines"></div>
      <div class="co-contact">
        <label for="email">Email for your receipt</label>
        <input id="email" type="email" inputmode="email" autocomplete="email" placeholder="you@example.com" aria-label="Email for your receipt" />
        <span id="emailLock" class="co-contact-hint" hidden>✓ Sending to your account email</span>
      </div>
      <div class="co-disc">
        <input id="code" placeholder="Discount code (try FREEBIE, LAUNCH30)" aria-label="Discount code" />
        <button class="btn ghost" id="apply">Apply</button>
        <span id="applied" class="co-applied" hidden></span>
        <span id="discMsg" class="co-msg"></span>
      </div>
      <div class="co-totals">
        <div class="co-trow"><span>Subtotal</span><span id="subtotal">$0.00</span></div>
        <div class="co-trow disc" id="discountRow" hidden><span id="discountLabel">Discount</span><span id="discountAmt"></span></div>
        <div class="co-trow" id="shippingRow" hidden><span>Shipping</span><span id="shippingAmt"></span></div>
        <div class="co-trow" id="taxRow" hidden><span>Sales tax</span><span id="taxAmt"></span></div>
        <div class="co-trow total"><span>Total</span><span id="total">$0.00</span></div>
      </div>
    </div>
    <div class="co-card card">
      <h2 style="margin-top:0">Shipping address</h2>
      <p class="addr-hint">For physical items (like the Founder Tee). Skip it if your order is digital only.</p>
      <div class="addr-grid">
        <input id="ad-name" class="addr-full" placeholder="Full name" autocomplete="name" aria-label="Full name" />
        <input id="ad-line1" class="addr-full" placeholder="Address line 1" autocomplete="address-line1" aria-label="Address line 1" />
        <input id="ad-line2" class="addr-full" placeholder="Address line 2 (optional)" autocomplete="address-line2" aria-label="Address line 2" />
        <input id="ad-city" placeholder="City" autocomplete="address-level2" aria-label="City" />
        <input id="ad-state" placeholder="State / Province" autocomplete="address-level1" aria-label="State or province" />
        <input id="ad-postal" placeholder="Postal code" autocomplete="postal-code" aria-label="Postal code" />
        <input id="ad-country" placeholder="Country (e.g. US)" autocomplete="country-name" aria-label="Country" />
      </div>
    </div>
    <div class="co-card card">
      <button class="btn" id="placeOrder">Place order</button>
      <p class="co-note">Stripe test mode — card <code>4242 4242 4242 4242</code>, any future date + CVC. $0 orders complete instantly, no card needed.</p>
      <p id="result" style="margin-top:10px"></p>
    </div>
  </div>

  <script is:inline>
    const money = (c) => (window.fmtMoney ? window.fmtMoney(c) : "$" + (Number(c || 0) / 100).toFixed(2));
    const esc = (s) => String(s || "").replace(/[&<>"]/g, (m) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[m]));
    const cart = () => JSON.parse(localStorage.getItem("cart") || "[]");
    const STRIPE_FLOOR = 50;
    const subtotal = () => cart().reduce((s, i) => s + i.priceCents * i.qty, 0);
    // server-authoritative discount state from the last /discount/validate ({ code, amount, total }) — or null.
    let disc = null;

    // ── Shipping address (optional; sent only when complete — the server re-sanitizes + ignores a partial one). ──
    const ADDR_IDS = { name: "ad-name", line1: "ad-line1", line2: "ad-line2", city: "ad-city", state: "ad-state", postalCode: "ad-postal", country: "ad-country" };
    function readAddr() {
      const a = {}; for (const k in ADDR_IDS) { const el = document.getElementById(ADDR_IDS[k]); a[k] = el ? el.value.trim() : ""; } return a;
    }
    function shipAddr() { // null unless every required field is filled (name/line1/city/postalCode/country)
      const a = readAddr();
      return (a.name && a.line1 && a.city && a.postalCode && a.country) ? a : null;
    }
    function restoreAddr() {
      let saved = null; try { saved = JSON.parse(localStorage.getItem("ship_addr") || "null"); } catch (e) {}
      if (saved) for (const k in ADDR_IDS) { const el = document.getElementById(ADDR_IDS[k]); if (el && saved[k]) el.value = saved[k]; }
    }
    function persistAddr() { try { localStorage.setItem("ship_addr", JSON.stringify(readAddr())); } catch (e) {} }

    // ── Receipt email + the contextual checkout banner — COOKIE-authoritative. ──
    // su_user is an optimistic hint only (can be stale → wrong locked email, or not-yet-set after a fresh sign-in →
    // false guest), so the email lock + the guest nudge are reconciled against the REAL session via get-session. The
    // Stripe-cancel banner (?cancelled=1) always wins the banner slot over the guest nudge.
    let signedInEmail = null;
    try { const su = JSON.parse(localStorage.getItem("su_user") || "null"); if (su && su.email) signedInEmail = String(su.email); } catch (e) {}
    const cancelledCheckout = !!new URLSearchParams(location.search).get("cancelled");
    const emailValid = (v) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);
    function emailValue() { return (document.getElementById("email").value || "").trim(); }
    let guestListener = false;
    function applyAuthEmail(verified) {
      signedInEmail = verified || null;
      const el = document.getElementById("email"), lock = document.getElementById("emailLock"), banner = document.getElementById("coBanner");
      if (signedInEmail) { el.value = signedInEmail; el.readOnly = true; lock.hidden = false; }
      else {
        el.readOnly = false; lock.hidden = true;
        if (!guestListener) { guestListener = true; try { const last = localStorage.getItem("guest_email"); if (last && !el.value) el.value = last; } catch (e) {} el.addEventListener("input", () => { try { localStorage.setItem("guest_email", emailValue()); } catch (e) {} }); }
      }
      if (cancelledCheckout) return; // the cancel banner owns the slot
      if (signedInEmail) banner.hidden = true;
      else { banner.className = "co-banner signin"; banner.hidden = false; banner.innerHTML = '👋 Checking out as a guest. <a href="/login?next=/checkout">Sign in</a> to track your order and save your details.'; }
    }
    function setupEmail() {
      if (cancelledCheckout) {
        const banner = document.getElementById("coBanner");
        banner.className = "co-banner info"; banner.hidden = false;
        banner.innerHTML = "↩︎ Payment cancelled — <b>no charge was made</b> and your cart is still here. Review it and try again whenever you're ready.";
        history.replaceState(null, "", location.pathname); // drop the ?cancelled flag
      }
      applyAuthEmail(signedInEmail); // optimistic (su_user hint), then reconcile with the verified session
      fetch("/api/auth/get-session", { credentials: "same-origin" }).then((r) => (r.ok ? r.json() : null)).then((s) => applyAuthEmail(s && s.user && s.user.email ? String(s.user.email) : null)).catch(() => {});
    }

    async function postJson(url, body, action) {
      const res = await fetch(url, { method: "POST", credentials: "same-origin", headers: { "content-type": "application/json", ...(action ? { "x-suluk-action": action } : {}) }, body: JSON.stringify(body) });
      let data = null; try { data = await res.json(); } catch (e) {}
      if (!res.ok) throw new Error((data && data.error) || ("Request failed (" + res.status + ")"));
      return data || {};
    }

    function renderLines() {
      const c = cart();
      document.getElementById("lines").innerHTML = c.length ? c.map((i) => `
        <div class="co-line">
          ${i.image ? `<img class="co-img" src="${esc(i.image)}" alt="" loading="lazy" />` : `<span class="co-img"></span>`}
          <div class="co-line-body">
            <div class="co-name">${esc(i.name || "#" + i.productId)}</div>
            ${i.variantLabel ? `<div class="co-variant">${esc(i.variantLabel)}</div>` : ""}
            <div class="co-qty">Qty ${i.qty} × ${money(i.priceCents)}</div>
          </div>
          <div class="co-line-price">${money(i.priceCents * i.qty)}</div>
        </div>`).join("") : `<p style="color:var(--muted)">Your cart is empty — <a href="/products">browse products</a>.</p>`;
    }

    // The server-authoritative breakdown (subtotal/discount/shipping/tax/total) from /checkout/quote — the SINGLE
    // source of truth for shipping + tax (the @suluk/stripe adapters). FAIL CLOSED: until a fresh quote exists we never
    // show a chargeable total or enable Pay (a subtotal-only number would understate the real shipping+tax charge).
    let quote = null, quoteError = false;
    function renderTotals() {
      const btn = document.getElementById("placeOrder");
      const dr = document.getElementById("discountRow"), sr = document.getElementById("shippingRow"), xr = document.getElementById("taxRow");
      if (!cart().length) {
        document.getElementById("subtotal").textContent = money(0); dr.hidden = true; sr.hidden = true; xr.hidden = true;
        document.getElementById("total").textContent = money(0); btn.disabled = true; btn.textContent = "Cart is empty"; return;
      }
      document.getElementById("subtotal").textContent = money(quote ? quote.subtotalCents : subtotal());
      if (!quote) { // computing (or failed) — the total isn't known yet; don't let the buyer pay a stale/understated amount
        dr.hidden = true; sr.hidden = true; xr.hidden = true;
        document.getElementById("total").textContent = quoteError ? "—" : "…";
        btn.disabled = !quoteError; btn.textContent = quoteError ? "Couldn't calculate total — retry" : "Calculating total…";
        return;
      }
      const discAmt = quote.discountCents, shipAmt = quote.shippingCents, taxAmt = quote.taxCents, total = quote.totalCents;
      if (discAmt > 0) { dr.hidden = false; document.getElementById("discountLabel").textContent = "Discount" + (disc ? " (" + disc.code + ")" : ""); document.getElementById("discountAmt").textContent = "−" + money(discAmt); } else { dr.hidden = true; }
      if (shipAmt > 0) { sr.hidden = false; document.getElementById("shippingAmt").textContent = money(shipAmt); } else { sr.hidden = true; }
      if (taxAmt > 0) { xr.hidden = false; document.getElementById("taxAmt").textContent = money(taxAmt); } else { xr.hidden = true; }
      document.getElementById("total").textContent = money(total);
      // a sold-out / over-qty line (server-checked) blocks the order BEFORE the buyer tries to pay — not a 409 surprise.
      if (quote.stockError) {
        btn.disabled = true; btn.textContent = "Sold out — adjust your cart";
        document.getElementById("result").innerHTML = `<span class="card" style="display:block;color:var(--accent)">${esc(quote.stockError)}</span>`;
        return;
      }
      document.getElementById("result").innerHTML = "";
      // single ADAPTIVE button: a chargeable total → Stripe; a $0/free total → complete now (no card).
      if (total >= STRIPE_FLOOR) { btn.disabled = false; btn.textContent = "Pay " + money(total) + " with Stripe →"; }
      else { btn.disabled = false; btn.textContent = "Place order — " + (total === 0 ? "Free" : money(total)); }
    }
    // Re-quote (debounced) on cart/discount change. Invalidate the stale quote first so renderTotals shows "Calculating"
    // + disables Pay until the fresh server total returns — the displayed Pay amount always equals what Stripe charges.
    let quoteTimer = null;
    function refreshQuote() {
      const c = cart();
      if (!c.length) { quote = null; quoteError = false; renderTotals(); return; }
      quote = null; quoteError = false; renderTotals();
      clearTimeout(quoteTimer);
      quoteTimer = setTimeout(async () => {
        try { quote = await postJson("/checkout/quote", { items: c, discountCode: disc && disc.code, shippingAddress: shipAddr() }); quoteError = false; }
        catch (e) { quote = null; quoteError = true; } // surface a retry — never silently understate the charge
        renderTotals();
      }, 250);
    }
    function render() { renderLines(); renderTotals(); refreshQuote(); }

    function showApplied(code) {
      const a = document.getElementById("applied");
      a.hidden = false; a.innerHTML = "✓ " + esc(code) + ' applied <button id="removeDisc" title="Remove" aria-label="Remove discount">×</button>';
      document.getElementById("removeDisc").addEventListener("click", removeDiscount);
      document.getElementById("code").value = ""; document.getElementById("discMsg").textContent = "";
    }
    function removeDiscount() {
      disc = null; if (window.discount) window.discount.clear();
      document.getElementById("applied").hidden = true; document.getElementById("discMsg").textContent = "";
      renderTotals(); refreshQuote();
    }
    async function applyCode(code, opts) {
      opts = opts || {};
      const r = await postJson("/discount/validate", { code, subtotalCents: subtotal(), items: cart() });
      if (r.valid) {
        disc = { code: code.toUpperCase(), amount: subtotal() - (typeof r.newTotalCents === "number" ? r.newTotalCents : subtotal()) };
        if (window.discount) window.discount.apply({ code: disc.code, type: r.discountType, value: r.discountValue });
        showApplied(disc.code);
      } else {
        disc = null; if (window.discount) window.discount.clear();
        document.getElementById("applied").hidden = true;
        if (!opts.silent) document.getElementById("discMsg").innerHTML = `<span style="color:var(--accent)">✗ ${esc(r.reason || "Invalid code.")}</span>`;
      }
      renderTotals(); refreshQuote();
    }

    document.getElementById("apply").addEventListener("click", async () => {
      const code = document.getElementById("code").value.trim(); if (!code) return;
      const b = document.getElementById("apply"); b.disabled = true;
      try { await applyCode(code); } catch (err) { if (window.toast) window.toast(err.message || "Could not validate the code.", { type: "error" }); } finally { b.disabled = false; }
    });
    document.getElementById("code").addEventListener("keydown", (e) => { if (e.key === "Enter") { e.preventDefault(); document.getElementById("apply").click(); } });

    document.getElementById("placeOrder").addEventListener("click", async () => {
      const c = cart(); if (!c.length) return;
      if (!quote) { if (quoteError) refreshQuote(); return; } // total not confirmed yet → never place at a guessed amount
      const email = emailValue();
      if (!emailValid(email)) { // a receipt needs a destination — block before creating the order
        const el = document.getElementById("email"); el.focus(); el.setAttribute("aria-invalid", "true");
        if (window.toast) window.toast("Enter your email so we can send your receipt.", { type: "error" });
        document.getElementById("result").innerHTML = `<span class="card" style="display:block;color:var(--accent)">Please enter a valid email for your receipt.</span>`;
        return;
      }
      document.getElementById("email").removeAttribute("aria-invalid");
      const btn = document.getElementById("placeOrder"); const lbl = btn.textContent; btn.disabled = true; btn.textContent = "Processing…";
      try {
        const r = await postJson("/checkout/pay", { items: c, discountCode: disc && disc.code, email, shippingAddress: shipAddr(), shippingMethod: quote && quote.shippingMethod }, "checkout");
        if (r.url) { location.href = r.url; return; } // chargeable → Stripe Checkout (leave the page)
        if (r.free || r.paid || r.order) { // free/$0 order completed server-side
          localStorage.removeItem("cart"); window.dispatchEvent(new Event("cart-changed")); if (window.discount) window.discount.clear(); disc = null;
          const oid = (r.order && r.order.id) || r.orderId;
          document.getElementById("result").innerHTML = `<span class="card" style="display:block">✓ Order #${oid} placed — ${money(r.totalCents)}. <a href="/dashboard">View it in your account →</a></span>`;
          if (window.toast) window.toast("Order placed ✓", { type: "success" });
          render();
        } else throw new Error(r.error || "Checkout could not complete.");
      } catch (err) {
        btn.disabled = false; btn.textContent = lbl;
        if (window.toast) window.toast(err.message || "Checkout failed.", { type: "error" });
        document.getElementById("result").innerHTML = `<span class="card" style="display:block;color:var(--accent)">${esc(err.message || "Checkout failed.")}</span>`;
      }
    });

    // restore a persisted discount (re-validate against the current cart so a now-ineligible code drops cleanly)
    (function () {
      const saved = window.discount && window.discount.get();
      if (saved && saved.code && subtotal() > 0) applyCode(saved.code, { silent: true }).then(() => { if (disc) showApplied(disc.code); });
    })();
    window.addEventListener("cart-changed", () => { if (disc) applyCode(disc.code, { silent: true }).catch(() => {}); else render(); });
    // address: restore the last-used one + persist on edit (kept across orders — most buyers ship to the same place)
    Object.values(ADDR_IDS).forEach((id) => { const el = document.getElementById(id); if (el) el.addEventListener("input", persistAddr); });
    restoreAddr();
    setupEmail(); // sets the receipt-email lock + the cancel/guest banner (cookie-authoritative)
    render();
  </script>
</Layout>
