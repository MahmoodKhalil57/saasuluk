---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
---
<Layout title="Checkout — saasuluk">
  <h1>Checkout</h1>
  <p class="tag">Your cart → an <b>Order</b> via the <code>/checkout</code> operation: it resolves the discount, computes the total, and is metered like everything else.</p>
  <table style="margin-top:16px"><thead><tr><th>Item</th><th>Qty</th><th>Price</th></tr></thead><tbody id="lines"></tbody></table>
  <div style="display:flex; gap:8px; margin:14px 0; align-items:center; flex-wrap:wrap">
    <input id="code" placeholder="Discount code (try SAVE10)" aria-label="Discount code" />
    <button class="btn ghost" id="apply">Apply</button>
    <span id="discMsg" style="color:var(--muted); font-size:13px"></span>
  </div>
  <p style="font-size:20px">Total: <b style="color:var(--accent)" id="total">$0.00</b></p>
  <div style="display:flex; gap:10px; flex-wrap:wrap">
    <button class="btn" id="stripe">Pay with Stripe →</button>
    <button class="btn ghost" id="pay">Place order (demo, no charge)</button>
  </div>
  <p style="color:var(--muted); font-size:13px; margin-top:8px">Stripe is in test mode — use card <code>4242 4242 4242 4242</code>, any future date + CVC.</p>
  <p id="result" style="margin-top:10px"></p>
  <script is:inline>
    const money = (c) => "$" + (Number(c || 0) / 100).toFixed(2);
    const cart = () => JSON.parse(localStorage.getItem("cart") || "[]");
    let discount = null;
    function subtotal() { return cart().reduce((s, i) => s + i.priceCents * i.qty, 0); }
    function applyLocal(sub) { if (!discount?.valid) return sub; return discount.discountType === "percent" ? Math.max(0, Math.round(sub * (100 - discount.discountValue) / 100)) : Math.max(0, sub - discount.discountValue); }
    function render() {
      const c = cart();
      document.getElementById("lines").innerHTML = c.length ? c.map((i) => `<tr><td>${i.name || "#" + i.productId}</td><td>${i.qty}</td><td>${money(i.priceCents * i.qty)}</td></tr>`).join("") : `<tr><td colspan="3" style="color:var(--muted)">Cart is empty — <a href="/products">browse products</a>.</td></tr>`;
      document.getElementById("total").textContent = money(applyLocal(subtotal()));
    }
    const applyBtn = document.getElementById("apply"), payBtn = document.getElementById("pay"), stripeBtn = document.getElementById("stripe");
    // POST JSON, throwing a useful Error on a network failure, a non-2xx, or a non-JSON body — so every handler
    // can show a real message instead of dying on `(await fetch()).json()` or assuming a success shape.
    async function postJson(url, body, action) {
      const res = await fetch(url, { method: "POST", headers: { "content-type": "application/json", "x-user": "demo-user", ...(action ? { "x-suluk-action": action } : {}) }, body: JSON.stringify(body) });
      let data = null; try { data = await res.json(); } catch (e) {}
      if (!res.ok) throw new Error((data && data.error) || ("Request failed (" + res.status + ")"));
      return data || {};
    }
    applyBtn.addEventListener("click", async () => {
      const code = document.getElementById("code").value.trim(); if (!code) return;
      applyBtn.disabled = true; // guard against double-apply
      try {
        const r = await postJson("/discount/validate", { code, subtotalCents: subtotal() });
        discount = r.valid ? { ...r, code } : null;
        document.getElementById("discMsg").textContent = r.valid ? `✓ ${r.discountType === "percent" ? r.discountValue + "% off" : money(r.discountValue) + " off"}` : `✗ ${r.reason || "invalid"}`;
        render();
      } catch (err) {
        if (window.toast) window.toast(err.message || "Could not validate the code.", { type: "error" });
      } finally { applyBtn.disabled = false; }
    });
    payBtn.addEventListener("click", async () => {
      const c = cart(); if (!c.length) return;
      const label = payBtn.textContent; payBtn.disabled = true; payBtn.textContent = "Placing…"; // double-submit guard
      try {
        const r = await postJson("/checkout/order", { items: c, discountCode: discount?.code }, "place-order");
        if (!r.order) throw new Error(r.error || "Order failed.");
        localStorage.removeItem("cart"); window.dispatchEvent(new Event("cart-changed")); discount = null; render(); // clear ONLY on success
        if (window.toast) window.toast("Order #" + r.order.id + " placed — total " + money(r.totalCents), { type: "success" });
        document.getElementById("result").innerHTML = `<span class="card" style="display:inline-block">✓ Order #${r.order.id} placed — total ${money(r.totalCents)}. <a href="/account">View in your account →</a></span>`;
      } catch (err) {
        if (window.toast) window.toast(err.message || "Could not place the order.", { type: "error" }); // cart preserved
      } finally { payBtn.disabled = false; payBtn.textContent = label; }
    });
    stripeBtn.addEventListener("click", async () => {
      const c = cart(); if (!c.length) return;
      stripeBtn.disabled = true; stripeBtn.textContent = "Redirecting to Stripe…";
      try {
        const r = await postJson("/checkout/pay", { items: c, discountCode: discount?.code }, "stripe-checkout");
        if (r.url) { location.href = r.url; return; } // success → leave the page (button stays disabled)
        throw new Error(r.error || "Could not start Stripe checkout.");
      } catch (err) {
        stripeBtn.disabled = false; stripeBtn.textContent = "Pay with Stripe →";
        if (window.toast) window.toast(err.message || "Could not start Stripe checkout.", { type: "error" });
        document.getElementById("result").innerHTML = `<span class="card" style="display:inline-block;color:#e5484d">${err.message || "Could not start Stripe checkout."}</span>`;
      }
    });
    // keep this page's cart table + total in sync when the shell drawer (or another tab) mutates the cart
    window.addEventListener("cart-changed", render);
    render();
  </script>
</Layout>
