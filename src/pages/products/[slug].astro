---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";
import { SEED_PRODUCTS } from "../../server/seed";
import { jsonLd } from "@suluk/builder";
export function getStaticPaths() {
  return SEED_PRODUCTS.map((p) => ({ params: { slug: p.slug }, props: { product: p } }));
}
const { product } = Astro.props;
const money = (c: number) => "$" + (c / 100).toFixed(c % 100 ? 2 : 0);
// Product structured data → rich results. The detail page is prerendered from SEED_PRODUCTS, so this matches
// exactly what's rendered (unlike the client-fetched lists), which is why JSON-LD belongs here and not on /faqs.
const productLd = jsonLd("Product", { name: product.name, description: product.description, price: (product.priceCents / 100).toFixed(2), currency: "USD" });
---
<Layout title={`${product.name} — saasuluk`} description={product.description} jsonLd={productLd}>
  <p style="margin:6px 0 14px"><a href="/products" class="pill">← Store</a></p>
  <div style="display:flex; gap:28px; flex-wrap:wrap; align-items:flex-start">
    <div style="width:300px; max-width:100%; aspect-ratio:1; border-radius:18px; background:linear-gradient(135deg,color-mix(in srgb,var(--accent) 18%,var(--panel)),var(--panel)); display:grid; place-items:center; border:1px solid var(--line)">
      <img src={`/avatar?seed=${product.slug}`} alt={product.name} width="120" height="120" style="border-radius:24px" />
    </div>
    <div style="flex:1; min-width:280px">
      <span class="pill accent">{product.priceCents === 0 ? "Open source" : "One-time · lifetime"}</span>
      <h1 style="margin:12px 0 8px">{product.name}</h1>
      <p class="tag" style="font-size:17px">{product.description}</p>
      <p style="font-size:36px; font-weight:800; letter-spacing:-.03em; margin:16px 0 6px">{money(product.priceCents)}</p>
      <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:10px">
        <button class="btn" id="add">Add to cart</button>
        <a class="btn ghost" href="/checkout">Go to checkout →</a>
      </div>
      <p id="cartmsg" style="color:var(--accent); font-size:14px; margin-top:10px"></p>
    </div>
  </div>

  <h2>Reviews</h2>
  <div id="reviews"><p style="color:var(--muted)">Loading reviews…</p></div>
  <form id="review" style="margin-top:14px; display:grid; gap:8px; max-width:480px">
    <div style="display:flex; gap:8px"><input name="title" placeholder="Review title" aria-label="Review title" required style="flex:1" /><select name="rating" aria-label="Rating (1-5 stars)"><option>5</option><option>4</option><option>3</option><option>2</option><option>1</option></select></div>
    <textarea name="body" placeholder="Your thoughts…" aria-label="Review text" rows="3"></textarea>
    <button class="btn" type="submit" style="justify-self:start">Submit review</button>
  </form>

  <h2>You might also like</h2>
  <div class="grid" id="related"></div>

  <script is:inline define:vars={{ product }}>
    const money = (c) => (window.fmtMoney ? window.fmtMoney(c) : "$" + (Number(c || 0) / 100).toFixed(2));
    const esc = (s) => String(s || "").replace(/[&<>]/g, (m) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;" }[m]));
    document.getElementById("add").addEventListener("click", () => {
      const c = JSON.parse(localStorage.getItem("cart") || "[]");
      const ex = c.find((i) => i.productId === product.id);
      if (ex) ex.qty++; else c.push({ productId: product.id, qty: 1, priceCents: product.priceCents, name: product.name });
      localStorage.setItem("cart", JSON.stringify(c));
      window.dispatchEvent(new Event("cart-changed"));
      if (window.toast) window.toast(product.name + " added to cart", { type: "success" });
      document.getElementById("cartmsg").textContent = "Added to cart ✓ — go to checkout when ready.";
    });
    async function loadReviews() {
      const rs = (await (await fetch("/review")).json()).filter((r) => r.productId === product.id && r.status === "published");
      document.getElementById("reviews").innerHTML = rs.length ? rs.map((r) => `<div class="card" style="margin-bottom:10px"><b style="font-family:inherit">${"★".repeat(r.rating)}${"☆".repeat(5 - r.rating)} ${esc(r.title)}</b><p>${esc(r.body)}</p><button class="pill" data-h="${r.id}" style="cursor:pointer;border:0">👍 helpful (${r.helpfulCount || 0})</button></div>`).join("") : `<p style="color:var(--muted)">No reviews yet — be the first.</p>`;
      document.querySelectorAll("[data-h]").forEach((b) => b.addEventListener("click", async () => { await fetch(`/review/${b.dataset.h}/helpful`, { method: "POST" }); loadReviews(); }));
    }
    document.getElementById("review").addEventListener("submit", async (e) => {
      e.preventDefault();
      const btn = e.target.querySelector("button[type=submit]"); btn.disabled = true; // prevent a duplicate review
      try {
        const r = await fetch("/review", { method: "POST", headers: { "content-type": "application/json", "x-user": "demo-user" }, body: JSON.stringify({ productId: product.id, rating: Number(e.target.rating.value), title: e.target.title.value, body: e.target.body.value, status: "published" }) });
        if (!r.ok) throw new Error("Could not submit your review.");
        e.target.reset(); loadReviews();
        if (window.toast) window.toast("Review submitted ✓", { type: "success" });
      } catch (err) {
        if (window.toast) window.toast(err.message || "Could not submit your review.", { type: "error" });
      } finally { btn.disabled = false; }
    });
    (async () => {
      const rel = await (await fetch(`/recommendations/${product.id}`)).json();
      document.getElementById("related").innerHTML = (rel.related || []).map((p) => `<div class="card"><a href="/products/${p.slug}"><b style="font-family:inherit">${esc(p.name)}</b></a><p>${money(p.priceCents)}</p></div>`).join("") || `<p style="color:var(--muted)">—</p>`;
    })();
    loadReviews();
  </script>
</Layout>
