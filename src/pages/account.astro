---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
---
<Layout title="Account — saasuluk">
  <div style="display:flex; gap:14px; align-items:center; flex-wrap:wrap">
    <img id="avatar" alt="" width="56" height="56" style="border-radius:50%;border:1px solid var(--line)" />
    <div style="flex:1; min-width:200px"><h1 style="font-size:28px;margin:0">Your account</h1><p class="tag" style="font-size:14px;margin:2px 0 0" id="sub">Loading…</p></div>
    <a id="signout" class="btn ghost sm" href="#" style="display:none">Sign out</a>
  </div>
  <div id="anon" class="card" style="display:none; margin-top:16px; background:color-mix(in srgb,var(--accent) 7%,var(--panel))">
    You're browsing as a demo user. <a href="/login">Sign in or create an account →</a> to make your orders, wishlist and tokens really yours.
  </div>
  <h2>Orders</h2>
  <table><thead><tr><th>#</th><th>Status</th><th>Total</th><th>Placed</th></tr></thead><tbody id="orders"></tbody></table>
  <h2>Wishlist</h2>
  <div class="grid" id="wishlist"></div>
  <h2>API tokens (developer)</h2>
  <form id="tok" style="display:flex; gap:8px; margin-bottom:8px"><input name="name" placeholder="Token name" aria-label="API token name" required /><button class="btn" type="submit">+ Create</button></form>
  <p id="newtok"></p>
  <table><thead><tr><th>Name</th><th>Prefix</th><th>Created</th><th></th></tr></thead><tbody id="tokens"></tbody></table>

  <div id="authed" style="display:none">
    <h2>Profile</h2>
    <form id="profile" style="display:flex; gap:8px; max-width:460px; align-items:center; flex-wrap:wrap">
      <input name="name" placeholder="Display name" aria-label="Display name" style="flex:1; min-width:180px" />
      <button class="btn" type="submit">Save</button>
      <span id="profmsg" style="color:var(--muted); font-size:13px"></span>
    </form>

    <h2>Active sessions</h2>
    <div id="sessions"></div>
    <button class="btn ghost sm" id="signout-all" style="margin-top:8px">Sign out of all other devices</button>

    <h2 style="color:#e5484d; margin-top:34px">Danger zone</h2>
    <div class="card" style="border-color:color-mix(in srgb,#e5484d 28%,var(--line))">
      <p style="margin:0 0 12px">Permanently delete your account and all your data — orders, wishlist, API tokens, billing. This cannot be undone.</p>
      <button class="btn" id="del-start" style="background:#e5484d">Delete my account</button>
      <div id="del-confirm" style="display:none; margin-top:12px; gap:8px; flex-wrap:wrap; align-items:center">
        <input id="del-pass" type="password" placeholder="Confirm your password" aria-label="Confirm password" style="max-width:240px" />
        <button class="btn" id="del-go" style="background:#e5484d">Yes, delete everything</button>
        <button class="btn ghost" id="del-cancel">Cancel</button>
        <span id="del-msg" style="color:#e5484d; font-size:13px; width:100%"></span>
      </div>
    </div>
  </div>
  <script is:inline>
    let USER = "demo-user";
    const money = (c) => (window.fmtMoney ? window.fmtMoney(c) : "$" + (Number(c || 0) / 100).toFixed(2));
    const when = (t) => t ? (window.fmtDate ? window.fmtDate(Number(t)) : new Date(Number(t)).toLocaleDateString()) : "—";
    async function resolveSession() {
      try {
        const s = await (await fetch("/api/auth/get-session", { credentials: "same-origin" })).json();
        if (s && s.user) {
          USER = s.user.id;
          document.getElementById("avatar").src = `/avatar?seed=${encodeURIComponent(s.user.email || USER)}`;
          document.getElementById("sub").innerHTML = `Signed in as <b>${s.user.name || s.user.email}</b> · ${s.user.email}`;
          const so = document.getElementById("signout"); so.style.display = "inline-flex";
          so.addEventListener("click", async (e) => { e.preventDefault(); await fetch("/api/auth/sign-out", { method: "POST", credentials: "same-origin" }); location.href = "/"; });
          setupAuthed(s.user); // profile / sessions / delete-account (signed-in only)
          return;
        }
      } catch (e) {}
      document.getElementById("avatar").src = `/avatar?seed=${USER}`;
      document.getElementById("sub").innerHTML = `Browsing as <b>demo-user</b>`;
      document.getElementById("anon").style.display = "block";
    }
    async function load() {
      const orders = (await (await fetch("/order")).json()).filter((o) => o.customerId === USER);
      document.getElementById("orders").innerHTML = orders.length ? orders.map((o) => `<tr><td>#${o.id}</td><td><span class="pill">${o.status}</span></td><td>${money(o.totalCents)}</td><td>${when(o.createdAt)}</td></tr>`).join("") : `<tr><td colspan="4" style="color:var(--muted)">No orders yet — <a href="/products">shop the store</a>.</td></tr>`;
      const wl = (await (await fetch("/wishlistItem")).json()).filter((w) => w.customerId === USER);
      const products = await (await fetch("/product")).json();
      document.getElementById("wishlist").innerHTML = wl.length ? wl.map((w) => { const p = products.find((x) => x.id === w.productId) || {}; return `<div class="card"><b style="font-family:inherit">${p.name || "#" + w.productId}</b><p>${money(p.priceCents)}</p></div>`; }).join("") : `<p style="color:var(--muted)">Empty — <a href="/products">add something →</a></p>`;
      loadTokens();
    }
    async function loadTokens() {
      const ts = (await (await fetch("/apiToken")).json()).filter((t) => t.userId === USER && !t.revokedAt);
      document.getElementById("tokens").innerHTML = ts.length ? ts.map((t) => `<tr><td>${t.name}</td><td><code>${t.prefix}…</code></td><td>${when(t.createdAt)}</td><td><button class="pill" data-r="${t.id}" style="cursor:pointer;border:0">revoke</button></td></tr>`).join("") : `<tr><td colspan="4" style="color:var(--muted)">No tokens.</td></tr>`;
      document.querySelectorAll("[data-r]").forEach((b) => b.addEventListener("click", async () => { await fetch(`/tokens/${b.dataset.r}/revoke`, { method: "POST", headers: { "x-user": USER } }); loadTokens(); }));
    }
    document.getElementById("tok").addEventListener("submit", async (e) => {
      e.preventDefault();
      const r = await (await fetch("/tokens/create", { method: "POST", headers: { "content-type": "application/json", "x-user": USER }, body: JSON.stringify({ name: e.target.name.value }) })).json();
      document.getElementById("newtok").innerHTML = `<span class="card" style="display:inline-block">New token <b style="font-family:ui-monospace,monospace">${r.token}</b> — copy it now, it won't be shown again. <button class="btn sm" data-test="${r.token}">Test it</button></span>`;
      document.querySelector("[data-test]").addEventListener("click", async (ev) => {
        const status = (await fetch("/apiToken", { headers: { authorization: "Bearer " + ev.target.dataset.test } })).status;
        ev.target.textContent = "Authenticated ✓ (" + status + ")";
      });
      e.target.reset(); loadTokens();
    });
    // ---- profile / sessions / delete (signed-in only) ----
    function setupAuthed(user) {
      document.getElementById("authed").style.display = "block";
      const pf = document.getElementById("profile");
      if (pf) { pf.elements["name"].value = user.name || ""; pf.addEventListener("submit", async (e) => {
        e.preventDefault();
        const r = await fetch("/api/auth/update-user", { method: "POST", headers: { "content-type": "application/json" }, credentials: "same-origin", body: JSON.stringify({ name: pf.elements["name"].value }) });
        document.getElementById("profmsg").textContent = r.ok ? "Saved ✓" : "Could not save.";
      }); }
      loadSessions();
      document.getElementById("signout-all")?.addEventListener("click", async () => {
        await fetch("/api/auth/revoke-other-sessions", { method: "POST", credentials: "same-origin" }); loadSessions();
        if (window.toast) window.toast("Signed out other devices.", { type: "success" });
      });
      const ds = document.getElementById("del-start"), dc = document.getElementById("del-confirm");
      ds?.addEventListener("click", () => { ds.style.display = "none"; dc.style.display = "flex"; });
      document.getElementById("del-cancel")?.addEventListener("click", () => { dc.style.display = "none"; ds.style.display = "inline-flex"; });
      document.getElementById("del-go")?.addEventListener("click", async () => {
        const password = document.getElementById("del-pass").value;
        const r = await fetch("/api/auth/delete-user", { method: "POST", headers: { "content-type": "application/json" }, credentials: "same-origin", body: JSON.stringify(password ? { password } : {}) });
        if (r.ok) { if (window.toast) window.toast("Account deleted.", { type: "success" }); location.href = "/"; }
        else { const d = await r.json().catch(() => ({})); document.getElementById("del-msg").textContent = d.message || d.error?.message || "Could not delete — check your password and try again."; }
      });
    }
    async function loadSessions() {
      try {
        const raw = await (await fetch("/api/auth/list-sessions", { credentials: "same-origin" })).json();
        const arr = Array.isArray(raw) ? raw : (raw.sessions || []);
        document.getElementById("sessions").innerHTML = arr.length
          ? arr.map((s) => `<div class="card" style="margin-bottom:6px; font-size:13.5px">${(s.userAgent || "Unknown device").slice(0, 70)} <span class="muted">· ${when(s.createdAt ? new Date(s.createdAt).getTime() : 0)}</span></div>`).join("")
          : '<p class="muted">No active sessions.</p>';
      } catch (e) { document.getElementById("sessions").innerHTML = ""; }
    }
    resolveSession().then(load);
  </script>
</Layout>
