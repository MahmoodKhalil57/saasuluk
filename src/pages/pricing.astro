---
import Layout from "../layouts/Layout.astro";
const tiers = [
  ["Free", "$0", ["1 project", "Community support", "Suluk docs"]],
  ["Pro", "$19/mo + usage", ["Unlimited projects", "Usage-metered billing (Stripe)", "Priority support"]],
  ["Enterprise", "Talk to us", ["SSO + roles (Better Auth)", "Self-host on Cloudflare", "Custom cost dashboards"]],
];
---
<Layout title="Pricing — saasuluk">
  <h1>Pricing</h1>
  <p class="tag">Usage is metered per user by <b>@suluk/cost</b> and billed through Stripe <b>Billing Meters</b> (<b>@suluk/stripe</b>). You see your real cost as it is; the price is the cost plus your margin.</p>
  <div class="grid" style="grid-template-columns:repeat(auto-fill,minmax(240px,1fr))">
    {tiers.map(([name, price, feats]) => (
      <div class="card">
        <b>{name}</b>
        <p style="color:var(--fg); font-size:20px; margin:6px 0">{price}</p>
        <ul style="margin:6px 0 0; padding-left:18px; color:var(--muted)">{feats.map((f) => <li>{f}</li>)}</ul>
      </div>
    ))}
  </div>
  <h2>How billing works</h2>
  <p class="tag">Each request's cost is traced from the frontend action → the operation → the third party (see <a href="/cost">/cost</a>). Those events become Stripe meter events; the metered price + your markup = revenue. Nothing is hidden — the cost is shown raw.</p>
</Layout>
