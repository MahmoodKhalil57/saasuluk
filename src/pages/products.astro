---
import Layout from "../layouts/Layout.astro";
---
<Layout title="Products — saasuluk">
  <h1>Products</h1>
  <p class="tag">The storefront — every product is a <b>Product</b> entity in the contract, served by the generated CRUD. Add to cart, then check out.</p>
  <form id="search" style="display:flex; gap:8px; margin:16px 0">
    <input name="q" placeholder="Search products…" />
    <button class="btn ghost" type="submit">Search</button>
  </form>
  <div class="grid" id="grid"></div>
  <script is:inline>
    const money = (c) => "$" + (Number(c || 0) / 100).toFixed(2);
    const cart = () => JSON.parse(localStorage.getItem("cart") || "[]");
    const setCart = (c) => localStorage.setItem("cart", JSON.stringify(c));
    function render(products) {
      document.getElementById("grid").innerHTML = products.length ? products.map((p) => `
        <div class="card">
          <img src="${p.imageUrl || `/avatar?seed=${encodeURIComponent(p.slug || p.name)}`}" alt="" style="width:100%;height:120px;object-fit:cover;border-radius:8px;background:#0b0e14" />
          <a href="/products/${p.slug}"><b style="font-family:inherit;font-size:15px">${p.name}</b></a>
          <p>${money(p.priceCents)} · ${p.inventory ?? 0} in stock</p>
          <button class="btn" data-id="${p.id}" data-name="${p.name}" data-price="${p.priceCents}" style="margin-top:8px;width:100%">Add to cart</button>
        </div>`).join("") : `<p style="color:var(--muted)">No products yet — seed some at <a href="/superadmin">/superadmin</a> or POST /product.</p>`;
      document.querySelectorAll("[data-id]").forEach((b) => b.addEventListener("click", () => {
        const c = cart(); const id = Number(b.dataset.id);
        const ex = c.find((i) => i.productId === id);
        if (ex) ex.qty++; else c.push({ productId: id, qty: 1, priceCents: Number(b.dataset.price), name: b.dataset.name });
        setCart(c); b.textContent = "Added ✓"; setTimeout(() => (b.textContent = "Add to cart"), 900);
      }));
    }
    async function load(q) {
      const url = q ? `/search?q=${encodeURIComponent(q)}` : "/product";
      const data = await (await fetch(url)).json();
      render(q ? data.products : data.filter((p) => p.status === "published"));
    }
    document.getElementById("search").addEventListener("submit", (e) => { e.preventDefault(); load(e.target.q.value.trim()); });
    load();
  </script>
</Layout>
