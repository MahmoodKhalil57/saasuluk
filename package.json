{
  "name": "saasuluk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SaaS starter on Astro + Hono, powered end-to-end by Suluk (the OpenAPI v4 candidate framework). A first-class Suluk template.",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "start": "bun dist/server/entry.mjs",
    "dev:api": "bun --hot src/server/main.ts",
    "test": "bun test",
    "preview": "bun dist/server/entry.mjs",
    "gen:openapi": "bun run scripts/gen-openapi.ts",
    "gen:seed": "bun run scripts/gen-seed.ts",
    "build:worker": "bun build worker/worker.ts --outfile worker/dist/worker.js --format esm --minify",
    "db:migrate:remote": "wrangler d1 execute saasuluk-db --file=./migrations/0000_domain.sql --remote",
    "db:seed:remote": "bun run gen:seed && wrangler d1 execute saasuluk-db --file=./scripts/seed.sql --remote",
    "promote:admins": "bun run scripts/promote-admins.ts",
    "deploy": "bun run build && bun run build:worker && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/node": "^10.1.4",
    "@astrojs/react": "^5.0.7",
    "@hono/zod-validator": "^0.8.0",
    "@hookform/resolvers": "^5.4.0",
    "@nanostores/query": "^0.3.4",
    "astro": "^6.4.5",
    "better-auth": "^1.6.16",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.25",
    "kysely": "^0.29.2",
    "kysely-d1": "^0.4.0",
    "nanostores": "^1.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.78.0",
    "stripe": "^22.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "wrangler": "^4.99.0"
  }
}